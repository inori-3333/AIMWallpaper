# ============================================================
# AIMWallpaper Environment Configuration
# Copy this file to config.yaml and fill in your values
# ============================================================

# --- AI Provider API Keys ---
# At least one provider must be configured
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# --- AI Provider Selection ---
# Options: openai, anthropic, ollama
AI_DEFAULT_PROVIDER=openai

# --- Ollama (local model, no API key needed) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# --- Embedding ---
# Options: openai, local
EMBEDDING_PROVIDER=openai

# --- Wallpaper Engine ---
# Path to your Wallpaper Engine installation directory
WALLPAPER_ENGINE_PATH=C:\Program Files (x86)\Steam\steamapps\common\wallpaper_engine
WALLPAPER_ENGINE_EXE=wallpaper32.exe

# --- Storage ---
DATA_DIR=./data
MAX_UPLOAD_SIZE_MB=500
PREVIEW_TIMEOUT_SECONDS=10
